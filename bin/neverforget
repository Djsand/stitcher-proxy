#!/usr/bin/env node

import fs from 'fs';
import path from 'path';
import os from 'os';
import readline from 'readline';
import { setupConfig, config, getConfigFilePath, saveConfig } from '../src/config.mjs';
import { startServer } from '../src/server.mjs';

// ─── Colors ────────────────────────────────────────────────
function c(text, color) {
  if (process.env.NO_COLOR) return text;
  const colors = {
    cyan: "\x1b[96m", green: "\x1b[92m", yellow: "\x1b[93m",
    red: "\x1b[91m", bold: "\x1b[1m", dim: "\x1b[2m", reset: "\x1b[0m"
  };
  return `${colors[color] || ""}${text}${colors.reset}`;
}

async function ask(q) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  return new Promise(resolve => rl.question(q, ans => { rl.close(); resolve(ans.trim()); }));
}

// ─── Start Proxy ───────────────────────────────────────────
async function startProxy(opts) {
  setupConfig(opts);

  console.log(`
  ${c("🧠 NeverForget", "bold")} ${c("v" + getVersion(), "dim")}
  
  ${c("Port:", "dim")}     ${c(config.port, "cyan")}
  ${c("Upstream:", "dim")} ${c(config.upstream_url, "cyan")}
  ${c("Tokens:", "dim")}   ${c(config.max_tokens.toLocaleString(), "cyan")}
  ${c("Storage:", "dim")}  ${c(config.data_dir, "dim")}
  `);

  console.log(c("  Ready. Point your LLM client at:", "green"));
  console.log(`  ${c(`http://localhost:${config.port}/v1`, "bold")}`);
  console.log();

  startServer();
}

function getVersion() {
  try {
    const pkg = JSON.parse(fs.readFileSync(new URL('../package.json', import.meta.url), 'utf8'));
    return pkg.version || '1.0.0';
  } catch { return '1.0.0'; }
}

// ─── Setup ─────────────────────────────────────────────────
async function runSetup() {
  setupConfig();
  console.log(`\n  ${c("🧠 NeverForget — Setup", "bold")}\n`);
  console.log(c("  Configure how the proxy behaves.", "dim"));
  console.log(c("  Press Enter to keep current value.\n", "dim"));

  const fields = [
    { key: "port", label: "Proxy port", type: "int" },
    { key: "upstream_url", label: "Upstream API", type: "str", hint: "e.g. https://api.openai.com or https://api.anthropic.com" },
    { key: "max_tokens", label: "Token budget", type: "int", hint: "max context window size" },
    { key: "dedup_threshold", label: "Dedup threshold", type: "float", hint: "0.0–1.0, higher = stricter dedup" },
    { key: "condense_threshold", label: "Condense threshold", type: "float", hint: "0.0–1.0, higher = more condensing" },
    { key: "roll_size_bytes", label: "File roll size (bytes)", type: "int", hint: "JSONL file size before archiving" },
  ];

  let changed = false;
  for (const { key, label, type, hint } of fields) {
    const current = config[key];
    const hintStr = hint ? c(` (${hint})`, "dim") : "";
    const raw = await ask(`  ${c(label, "bold")}${hintStr}\n  ${c(`[${current}]`, "dim")} > `);

    if (!raw) continue;

    let val = raw;
    if (type === "int") { val = parseInt(raw, 10); if (isNaN(val)) { console.log(c("  ⚠ Invalid number, skipped", "yellow")); continue; } }
    if (type === "float") { val = parseFloat(raw); if (isNaN(val)) { console.log(c("  ⚠ Invalid number, skipped", "yellow")); continue; } }

    config[key] = val;
    changed = true;
    console.log(c(`  ✓ ${key} → ${val}`, "green"));
    console.log();
  }

  if (changed) {
    saveConfig();
    console.log(c(`  ✅ Saved to ${getConfigFilePath()}`, "green"));
  } else {
    console.log(c("  No changes.", "dim"));
  }
  console.log();
}

// ─── Integrate ─────────────────────────────────────────────
function addToShellProfile(line) {
  const shell = process.env.SHELL || "/bin/zsh";
  let profile;
  if (shell.includes("zsh")) profile = path.join(os.homedir(), ".zshrc");
  else if (shell.includes("bash")) profile = path.join(os.homedir(), ".bashrc");
  else profile = path.join(os.homedir(), ".profile");

  const existing = fs.existsSync(profile) ? fs.readFileSync(profile, "utf-8") : "";
  if (existing.includes(line)) return { profile, added: false };

  fs.appendFileSync(profile, `\n# NeverForget — infinite LLM memory\n${line}\n`);
  return { profile, added: true };
}

function integrate(target) {
  setupConfig();
  const base = `http://localhost:${config.port}/v1`;

  const tools = {
    "claude-code": { env: "ANTHROPIC_BASE_URL", name: "Claude Code", cmd: "claude" },
    "codex":       { env: "OPENAI_BASE_URL", name: "Codex CLI", cmd: "codex" },
    "cursor":      { env: "OPENAI_BASE_URL", name: "Cursor", cmd: null },
    "openclaw":    { env: "OPENAI_BASE_URL", name: "OpenClaw", cmd: "openclaw" },
  };

  if (!target || target === "help") {
    console.log(`\n  ${c("🧠 NeverForget — Integrations", "bold")}\n`);
    console.log(`  ${c("neverforget integrate all", "green")}           Set up everything at once`);
    console.log();
    for (const [key, { name }] of Object.entries(tools)) {
      console.log(`  ${c(`neverforget integrate ${key}`, "cyan").padEnd(52)} ${name}`);
    }
    console.log(`\n  Each command adds the right env var to your shell profile.`);
    console.log(`  Your API keys stay with your client — NeverForget just proxies.\n`);
    return;
  }

  if (target === "all") {
    console.log(`\n  ${c("🧠 Configuring all integrations...", "bold")}\n`);
    const envVars = new Set();
    for (const { env } of Object.values(tools)) envVars.add(`export ${env}=${base}`);

    let anyAdded = false;
    let profilePath;
    for (const line of envVars) {
      const { profile, added } = addToShellProfile(line);
      profilePath = profile;
      if (added) {
        console.log(`  ${c("✓", "green")} Added: ${c(line, "cyan")}`);
        anyAdded = true;
      } else {
        console.log(`  ${c("·", "dim")} Already set: ${c(line, "dim")}`);
      }
    }

    console.log();
    if (anyAdded) {
      console.log(`  ${c("✅ Updated", "green")} ${profilePath}`);
      console.log(`  Run ${c(`source ${profilePath}`, "yellow")} or open a new terminal.`);
    } else {
      console.log(`  ${c("✅ Everything already configured.", "green")}`);
    }
    console.log(`\n  Now run ${c("claude", "bold")}, ${c("codex", "bold")}, or any OpenAI client — they'll route through NeverForget.\n`);
    return;
  }

  const tool = tools[target];
  if (!tool) {
    console.log(c(`\n  Unknown tool: ${target}. Run 'neverforget integrate' for options.\n`, "red"));
    return;
  }

  console.log(`\n  ${c(`🧠 Configuring ${tool.name}...`, "bold")}\n`);
  const line = `export ${tool.env}=${base}`;
  const { profile, added } = addToShellProfile(line);

  if (added) {
    console.log(`  ${c("✓", "green")} Added to ${profile}:`);
    console.log(`    ${c(line, "cyan")}`);
    console.log(`\n  Run ${c(`source ${profile}`, "yellow")} or open a new terminal.`);
  } else {
    console.log(`  ${c("✅ Already configured in", "green")} ${profile}`);
  }
  if (tool.cmd) {
    console.log(`  Then just run ${c(tool.cmd, "bold")} as normal.\n`);
  }
  console.log();
}

// ─── Status ────────────────────────────────────────────────
function statusCmd() {
  setupConfig();
  let sessions = 0;
  if (fs.existsSync(config.data_dir)) {
    sessions = fs.readdirSync(config.data_dir).filter(f => {
      try { return fs.statSync(path.join(config.data_dir, f)).isDirectory(); } catch { return false; }
    }).length;
  }
  console.log(`
  ${c("🧠 NeverForget Status", "bold")}

  ${c("Port:", "dim")}       ${config.port}
  ${c("Upstream:", "dim")}   ${config.upstream_url}
  ${c("Tokens:", "dim")}     ${config.max_tokens.toLocaleString()}
  ${c("Sessions:", "dim")}   ${sessions}
  ${c("Storage:", "dim")}    ${config.data_dir}
  ${c("Config:", "dim")}     ${getConfigFilePath()}
  `);
}

// ─── Sessions ──────────────────────────────────────────────
function sessionsCmd(args) {
  setupConfig();
  if (args[0] === "purge" && args[1]) {
    const sessionDir = path.join(config.data_dir, args[1]);
    if (fs.existsSync(sessionDir) && fs.statSync(sessionDir).isDirectory()) {
      fs.rmSync(sessionDir, { recursive: true, force: true });
      console.log(c(`  ✅ Purged: ${args[1]}`, "green"));
    } else {
      console.log(c(`  ❌ Not found: ${args[1]}`, "red"));
    }
    return;
  }

  console.log(`\n  ${c("🧠 Sessions", "bold")}\n`);
  if (!fs.existsSync(config.data_dir)) { console.log("  No sessions yet.\n"); return; }

  const dirs = fs.readdirSync(config.data_dir);
  if (dirs.length === 0) { console.log("  No sessions yet.\n"); return; }

  for (const d of dirs) {
    const dpath = path.join(config.data_dir, d);
    try {
      if (!fs.statSync(dpath).isDirectory()) continue;
    } catch { continue; }
    let size = 0, msgs = 0;
    for (const f of fs.readdirSync(dpath)) {
      const fp = path.join(dpath, f);
      try { size += fs.statSync(fp).size; } catch {}
      if (f.endsWith(".jsonl")) {
        try { msgs += fs.readFileSync(fp, 'utf-8').split('\n').filter(l => l.trim()).length; } catch {}
      }
    }
    console.log(`  ${c(d, "cyan")}  ${msgs} msgs  ${(size / 1024).toFixed(0)} KB`);
  }
  console.log(`\n  Purge: ${c("neverforget sessions purge <name>", "dim")}\n`);
}

// ─── Config ────────────────────────────────────────────────
function configCmd(args) {
  setupConfig();
  if (args[0] === "set" && args[1] && args[2]) {
    const key = args[1];
    if (!(key in config)) {
      console.log(c(`  ❌ Unknown: ${key}`, "red"));
      return;
    }
    let val = args[2];
    if (typeof config[key] === "number") {
      val = config[key] % 1 === 0 ? parseInt(val, 10) : parseFloat(val);
    }
    config[key] = val;
    saveConfig();
    console.log(c(`  ✅ ${key} → ${val}`, "green"));
    return;
  }

  console.log(`\n  ${c("🧠 Config", "bold")}  ${c(getConfigFilePath(), "dim")}\n`);
  const display = { ...config };
  if (display.api_key) display.api_key = "***";
  for (const [k, v] of Object.entries(display)) {
    console.log(`  ${c(k, "cyan").padEnd(35)} ${v}`);
  }
  console.log(`\n  Edit: ${c("neverforget setup", "dim")} or ${c("neverforget config set <key> <value>", "dim")}\n`);
}

// ─── Help ──────────────────────────────────────────────────
function showHelp() {
  console.log(`
  ${c("🧠 NeverForget", "bold")} — Infinite memory for LLMs

  ${c("Usage:", "bold")}

    ${c("neverforget", "green")}                       Start the proxy ${c("(default)", "dim")}
    ${c("neverforget setup", "green")}                 Configure settings interactively
    ${c("neverforget integrate [tool]", "green")}      Auto-configure Claude Code, Codex, Cursor, etc.
    ${c("neverforget status", "green")}                Show current config + sessions
    ${c("neverforget sessions", "green")}              List all sessions
    ${c("neverforget sessions purge <id>", "green")}   Delete a session
    ${c("neverforget config", "green")}                Show config values
    ${c("neverforget config set <k> <v>", "green")}    Set a config value

  ${c("Options:", "bold")}

    --port <n>         Port ${c("(default: 8081)", "dim")}
    --upstream <url>   Upstream API ${c("(default: https://api.openai.com)", "dim")}
    --max-tokens <n>   Token budget ${c("(default: 128000)", "dim")}

  ${c("Quick start:", "bold")}

    ${c("$", "dim")} npm i -g neverforget
    ${c("$", "dim")} neverforget
    ${c("$", "dim")} neverforget integrate all
  `);
}

// ─── Main ──────────────────────────────────────────────────
async function main() {
  const args = process.argv.slice(2);
  let command = null;

  // Parse command (first non-flag arg)
  const remaining = [];
  const opts = {};
  for (let i = 0; i < args.length; i++) {
    if (args[i] === "--help" || args[i] === "-h") { showHelp(); return; }
    else if (args[i] === "--port" && args[i+1]) { opts.port = parseInt(args[++i], 10); }
    else if (args[i] === "--upstream" && args[i+1]) { opts.upstream = args[++i]; }
    else if (args[i] === "--max-tokens" && args[i+1]) { opts.max_tokens = parseInt(args[++i], 10); }
    else if (args[i] === "--data-dir" && args[i+1]) { opts.data_dir = args[++i]; }
    else if (!command && !args[i].startsWith("-")) { command = args[i]; }
    else if (command && !args[i].startsWith("-")) { remaining.push(args[i]); }
  }

  switch (command) {
    case "setup":     await runSetup(); break;
    case "init":      await runSetup(); break;  // alias
    case "integrate": integrate(remaining[0]); break;
    case "status":    statusCmd(); break;
    case "sessions":  sessionsCmd(remaining); break;
    case "config":    configCmd(remaining); break;
    case "help":      showHelp(); break;
    case "start":     await startProxy(opts); break;
    default:          await startProxy(opts); break;
  }
}

main().catch(err => {
  console.error(c(`  Fatal: ${err.message}`, "red"));
  process.exit(1);
});
