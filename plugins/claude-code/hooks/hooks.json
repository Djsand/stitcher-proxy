{
  "description": "NeverForget — auto-start proxy and report session status",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-proxy.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
